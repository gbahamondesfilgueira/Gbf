@model Empresa

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@if (TempData["Warning"] != null)
{
    <div class="alert alert-warning alert-dismissible fade show" role="alert">
        @TempData["Warning"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        @TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@{
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<link rel="stylesheet" href="~/css/empresa-perfil.css" />

<div class="container-fluid">

    <!-- COVER -->
    <div class="cover">
        <img src="@Model.LogoUrl" class="avatar" />
    </div>

    <!-- HEADER -->
    <div class="profile-header">
        <h3>@Model.Nombre</h3>
        <span class="badge @(Model.Activo ? "bg-success" : "bg-danger")">
            @(Model.Activo ? "Activa" : "Inactiva")
        </span>
    </div>

    <div class="row mt-4">

        <!-- IZQUIERDA -->
        <div class="col-md-4">

            <div class="card mb-3 p-3">
                <h5>Información</h5>
                <p><strong>RUT:</strong> @Model.Rut</p>
                <p><strong>Email:</strong> @Model.Email</p>
                <p><strong>Teléfono:</strong> @Model.Telefono</p>
            </div>

        </div>

        <!-- DERECHA -->
        <div class="col-md-8">

            <!-- VEHICULOS -->
            <div class="card mb-3">

                <div class="card-header d-flex justify-content-between align-items-center">

                    <button class="btn btn-link text-decoration-none p-0"
                            type="button"
                            data-bs-toggle="collapse"
                            data-bs-target="#vehiculosCollapse">
                        <strong>Vehículos</strong>
                    </button>

                    <div class="d-flex gap-2">
                        <button class="btn btn-primary btn-sm" data-bs-toggle="modal" data-bs-target="#modalVehiculo">
                            + Agregar
                        </button>

                        <button class="btn btn-success btn-sm" data-bs-toggle="modal" data-bs-target="#modalCargaMasiva">
                            Carga Masiva
                        </button>
                    </div>

                </div>

                <!-- 🔴 AHORA CERRADO -->
                <div id="vehiculosCollapse" class="collapse">

                    <ul class="list-group list-group-flush">
                        @foreach (var v in ViewBag.Vehiculos)
                        {
                            <li class="list-group-item d-flex justify-content-between align-items-center">

                                <span>
                                    <strong>@v.Patente</strong> - @v.Marca @v.Modelo
                                </span>

                                <div>
                                    <span class="badge @(v.Activo ? "bg-success" : "bg-secondary") me-2">
                                        @(v.Activo ? "Activo" : "Inactivo")
                                    </span>

                                    @if (v.Activo)
                                    {
                                        <button onclick="toggleVehiculo(@v.Id, true)" class="btn btn-danger btn-sm">
                                            Desactivar
                                        </button>
                                    }
                                    else
                                    {
                                        <button onclick="toggleVehiculo(@v.Id, false)" class="btn btn-success btn-sm">
                                            Activar
                                        </button>
                                    }
                                </div>

                            </li>
                        }
                    </ul>

                </div>

            </div>

            <!-- CONDUCTORES -->
            <div class="card mb-3">

                <div class="card-header d-flex justify-content-between align-items-center">

                    <button class="btn btn-link text-decoration-none p-0"
                            type="button"
                            data-bs-toggle="collapse"
                            data-bs-target="#conductoresCollapse">
                        <strong>Conductores</strong>
                    </button>

                    <div class="d-flex gap-2">
                        <button class="btn btn-primary btn-sm" data-bs-toggle="modal" data-bs-target="#modalConductor">
                            + Agregar
                        </button>

                        <button class="btn btn-success btn-sm" data-bs-toggle="modal" data-bs-target="#modalCargaConductores">
                            Carga Masiva
                        </button>
                    </div>

                </div>

                <!-- 🔴 AHORA CERRADO -->
                <div id="conductoresCollapse" class="collapse">

                    <ul class="list-group list-group-flush">
                        @foreach (var c in ViewBag.Conductores)
                        {
                            <li class="list-group-item d-flex justify-content-between align-items-center">

                                <div class="d-flex align-items-center gap-3">
                                    <img src="@(c.FotoPerfilUrl ?? "/img/default-avatar.png")"
                                         style="width:45px;height:45px;border-radius:50%;object-fit:cover" />

                                    <div>
                                        <strong>@c.Nombre @c.Apellido</strong><br />
                                        <small>@c.Rut</small>
                                    </div>
                                </div>

                                <div>
                                    <span class="badge @(c.Activo ? "bg-success" : "bg-secondary") me-2">
                                        @(c.Activo ? "Activo" : "Inactivo")
                                    </span>

                                    @if (c.Activo)
                                    {
                                        <button onclick="toggleConductor(@c.Id, true)" class="btn btn-danger btn-sm">
                                            Desactivar
                                        </button>
                                    }
                                    else
                                    {
                                        <button onclick="toggleConductor(@c.Id, false)" class="btn btn-success btn-sm">
                                            Activar
                                        </button>
                                    }
                                </div>

                            </li>
                        }
                    </ul>

                </div>

            </div>

            <!-- PIONETAS -->
            <div class="card mb-3">

                <div class="card-header d-flex justify-content-between align-items-center">

                    <button class="btn btn-link text-decoration-none p-0"
                            type="button"
                            data-bs-toggle="collapse"
                            data-bs-target="#pionetasCollapse">
                        <strong>Pionetas</strong>
                    </button>

                    <div class="d-flex gap-2">
                        <button class="btn btn-primary btn-sm" data-bs-toggle="modal" data-bs-target="#modalPioneta">
                            + Agregar
                        </button>

                        <button class="btn btn-success btn-sm" data-bs-toggle="modal" data-bs-target="#modalCargaPionetas">
                            Carga Masiva
                        </button>
                    </div>

                </div>

                <!-- 🔴 AHORA CERRADO -->
                <div id="pionetasCollapse" class="collapse">

                    <ul class="list-group list-group-flush">
                        @foreach (var p in ViewBag.Pionetas)
                        {
                            <li class="list-group-item d-flex justify-content-between align-items-center">

                                <span>
                                    <strong>@p.Nombre @p.Apellido</strong> - @p.Rut
                                </span>

                                <div>
                                    <span class="badge @(p.Activo ? "bg-success" : "bg-secondary") me-2">
                                        @(p.Activo ? "Activo" : "Inactivo")
                                    </span>

                                    @if (p.Activo)
                                    {
                                        <button onclick="togglePioneta(@p.Id, true)" class="btn btn-danger btn-sm">
                                            Desactivar
                                        </button>
                                    }
                                    else
                                    {
                                        <button onclick="togglePioneta(@p.Id, false)" class="btn btn-success btn-sm">
                                            Activar
                                        </button>
                                    }
                                </div>

                            </li>
                        }
                    </ul>

                </div>

            </div>

        </div>

    </div>

</div>

<script>
    async function toggleVehiculo(id, activo) {
        const url = activo ? `/Vehiculo/Desactivar/${id}` : `/Vehiculo/Activar/${id}`;
        await fetch(url);
        location.reload();
    }

    async function toggleConductor(id, activo) {
        const url = activo ? `/Conductor/Desactivar/${id}` : `/Conductor/Activar/${id}`;
        await fetch(url);
        location.reload();
    }

    async function togglePioneta(id, activo) {
        const url = activo ? `/Pioneta/Desactivar/${id}` : `/Pioneta/Activar/${id}`;
        await fetch(url);
        location.reload();
    }
</script>

<!-- MODAL CONDUCTOR -->
<div class="modal fade" id="modalConductor" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">

            <form asp-controller="Conductor"
                  asp-action="Crear"
                  method="post"
                  enctype="multipart/form-data">

                <div class="modal-header">
                    <h5 class="modal-title">Registrar Conductor</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>

                <div class="modal-body">

                    <input type="hidden" name="EmpresaId" value="@Model.Id" />

                    <div class="row">
                        <div class="col-md-6">
                            <label>Nombre</label>
                            <input name="Nombre" class="form-control" required />
                        </div>

                        <div class="col-md-6">
                            <label>Apellido</label>
                            <input name="Apellido" class="form-control" required />
                        </div>
                    </div>

                    <div class="row mt-2">
                        <div class="col-md-6">
                            <label>RUT</label>
                            <input name="Rut" class="form-control" required />
                        </div>

                        <div class="col-md-6">
                            <label>Fecha Nacimiento</label>
                            <input type="date" name="FechaNacimiento" class="form-control" required />
                        </div>
                    </div>

                    <div class="mt-2">
                        <label>Clase Licencia</label>
                        <select name="ClaseLicencia" class="form-select" required>
                            <option value="">Seleccione</option>
                            <option>A1</option>
                            <option>A2</option>
                            <option>A3</option>
                            <option>A4</option>
                            <option>A5</option>
                            <option>B</option>
                            <option>C</option>
                            <option>D</option>
                            <option>E</option>
                        </select>
                    </div>

                    <hr />

                    <h6>Documentación (Opcional)</h6>

                    <input type="file" name="carnetFrontal" class="form-control mb-2" />
                    <input type="file" name="carnetTrasero" class="form-control mb-2" />
                    <input type="file" name="licenciaFrontal" class="form-control mb-2" />
                    <input type="file" name="licenciaTrasera" class="form-control mb-2" />
                    <input type="file" name="certificado" class="form-control mb-2" />
                    <input type="file" name="foto" class="form-control mb-2" />

                </div>

                <div class="modal-footer">
                    <button class="btn btn-success">Guardar</button>
                </div>

            </form>

        </div>
    </div>
</div>
<div class="modal fade" id="modalCargaConductores" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">

            <div class="modal-header">
                <h5 class="modal-title">Carga Masiva de Conductores</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>

            <div class="modal-body">

                <!-- DESCARGA -->
                <div class="mb-3">
                    <label>Descargar plantilla</label>

                    <a href="~/plantillas/plantilla_conductores.csv"
                       class="btn btn-outline-primary w-100"
                       download>
                        Descargar archivo ejemplo
                    </a>
                </div>

                <hr />

                <!-- SUBIDA -->
                <form method="post"
                      enctype="multipart/form-data"
                      asp-controller="Conductor"
                      asp-action="ImportarCsv">

                    <input type="hidden" name="empresaId" value="@Model.Id" />

                    <div class="mb-3">
                        <label>Seleccionar archivo CSV</label>
                        <input type="file" name="archivo" class="form-control" required />
                    </div>

                    <button class="btn btn-success w-100">
                        Subir archivo
                    </button>

                </form>

            </div>

        </div>
    </div>
</div>

<!-- MODAL VEHICULO -->
<div class="modal fade" id="modalVehiculo" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">

            <form asp-controller="Vehiculo" asp-action="Crear" method="post">

                <div class="modal-header">
                    <h5 class="modal-title">Registrar Vehículo</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>

                <div class="modal-body">

                    <input type="hidden" name="EmpresaId" value="@Model.Id" />

                    <div class="mb-2">
                        <label>Patente</label>
                        <input type="text" name="Patente" class="form-control" required />
                    </div>

                    <div class="mb-2">
                        <label>Marca</label>
                        <input type="text" name="Marca" class="form-control" required />
                    </div>

                    <div class="mb-2">
                        <label>Modelo</label>
                        <input type="text" name="Modelo" class="form-control" required />
                    </div>

                    <div class="mb-2">
                        <label>Color</label>
                        <input type="text" name="Color" class="form-control" />
                    </div>

                    <div class="mb-2">
                        <label>Tipo</label>
                        <input type="text" name="Tipo" class="form-control" />
                    </div>

                    <div class="mb-2">
                        <label>Año</label>
                        <input type="number" name="Año" class="form-control" />
                    </div>

                </div>

                <div class="modal-footer">
                    <button class="btn btn-success">Guardar</button>
                </div>

            </form>

        </div>
    </div>
</div>
