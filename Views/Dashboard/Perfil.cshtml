@model Empresa

<div class="container mt-3">

    <!-- HEADER TIPO FACEBOOK -->
    <div class="card">
        <div class="p-3 d-flex align-items-center">
            <img src="@Model.LogoUrl" style="height:80px;" class="me-3" />
            <div>
                <h4>@Model.Nombre</h4>
                <span class="badge @(Model.Activo ? "bg-success" : "bg-danger")">
                    @(Model.Activo ? "Activa" : "Inactiva")
                </span>
            </div>
        </div>
    </div>

    <!-- KPIs -->
    <div class="row mt-3 text-center">

        <div class="col-md-3">
            <div class="card p-3">
                <h6>Vehículos Activos</h6>
                <h3>@Model.Vehiculos.Count(v => v.Activo)</h3>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card p-3">
                <h6>Conductores</h6>
                <h3>@Model.Conductores.Count()</h3>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card p-3">
                <h6>Pionetas</h6>
                <h3>@Model.Pionetas.Count()</h3>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card p-3">
                <h6>Incidentes</h6>
                <h3>@Model.Incidentes.Count()</h3>
            </div>
        </div>

    </div>

    <!-- DOCUMENTOS / IMÁGENES -->
    <div class="card mt-4 p-3">
        <h5>Documentos e Imágenes</h5>

        <form method="post" enctype="multipart/form-data" asp-action="SubirArchivo">
            <input type="hidden" name="empresaId" value="@Model.Id" />
            <input type="file" name="archivo" class="form-control mb-2" />
            <button class="btn btn-primary">Subir</button>
        </form>

        <div class="mt-3">
            @foreach (var doc in Model.Documentos)
            {
                <div>
                    <a href="@doc.Ruta" target="_blank">@doc.Nombre</a>
                </div>
            }
        </div>
    </div>

</div>